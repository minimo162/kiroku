{
  "name": "kiroku",
  "version": "0.1.0",
  "description": "Kiroku desktop app built with Tauri v2, Svelte 5, and Rust.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build:copilot": "esbuild src/copilot_server.ts --bundle --platform=node --format=esm --external:playwright --outfile=src-tauri/binaries/copilot_server.js",
    "build": "npm run build:copilot && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri": "tauri"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.13.14",
    "@tauri-apps/cli": "^2",
    "esbuild": "^0.25.12",
    "playwright": "^1.58.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
